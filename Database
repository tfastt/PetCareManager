-- DATABASE PETMANAGEMENTDB

-- Table: Owner
CREATE TABLE Owner (
    OwnerID INT PRIMARY KEY IDENTITY(1,1),
    OwnerName NVARCHAR(100),
    Phone NVARCHAR(20),
    Address NVARCHAR(255)
);

-- Table: Pet
CREATE TABLE Pet (
    PetID INT PRIMARY KEY IDENTITY(1,1),
    PetName NVARCHAR(100) NOT NULL,
    Species NVARCHAR(50),
    Breed NVARCHAR(50),
    Age INT CHECK (Age >= 0),
    OwnerID INT,
    Gender NVARCHAR(10),
    Note NVARCHAR(255),
    FOREIGN KEY (OwnerID) REFERENCES Owner(OwnerID)
);

-- Table: Vaccine
CREATE TABLE Vaccine (
    VaccineID INT PRIMARY KEY IDENTITY(1,1),
    PetID INT,
    VaccineName NVARCHAR(100),
    InjectionDate DATE,
    NextInjectionDate DATE,
    Note NVARCHAR(255),
    FOREIGN KEY (PetID) REFERENCES Pet(PetID)
);
